set_io clk    35
set_io led_b  39
set_io led_r  40
set_io led_g  41
set_io uart_tx 4
set_io uart_rx 6
set_io btn_s2  18

# GPIO[0..7] — directly accessible iCESugar 1.5 header pins.
set_io gpio[0] 36
set_io gpio[1] 37
set_io gpio[2] 38
set_io gpio[3] 42
set_io gpio[4] 43
set_io gpio[5] 44
set_io gpio[6] 45
set_io gpio[7] 46

# I2C — placeholder pins. External pull-ups (2.2–10 kΩ) required.
set_io i2c_scl 25
set_io i2c_sda 26

# Sigma-delta ADC — placeholder pins. Wire as in mpu/adc.v: external R-R-C
# network between adc_out, the analog input, and adc_in.
set_io adc_in  27
set_io adc_out 28

# SPI flash — same pins the iCE40 uses to load its own bitstream.
# After configuration the FPGA is free to drive them to read user data.
set_io flash_sck  15
set_io flash_ss   16
set_io flash_si   14
set_io flash_so   17
