10 LET A$ = "HELLO"
20 LET B$ = ", WORLD"
30 LET C$ = A$ + B$ + "!"
40 PRINT C$
50 IF A$ = "HELLO" THEN PRINT "MATCH"
60 IF A$ <> B$ THEN PRINT "DIFFERENT"
70 LET P = MALLOC(8)
80 POKE P, 72
90 POKE P + 1, 73
100 POKE P + 2, 0
110 PRINT "BYTE AT P  : "; PEEK(P)
120 PRINT "BYTE AT P+1: "; PEEK(P + 1)
130 END
