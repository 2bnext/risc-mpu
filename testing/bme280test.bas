10 REM ----- BME280 demo in BASIC -----
20 REM Reads compensated T/P/H from a BME280 at I2C address 0x76.
30 REM Uses 32-bit reference compensation from the Bosch datasheet.
40 REM Globals are used heavily because BASIC has no functions.
50 REM
60 REM Locations of subroutines:
70 REM   1000 BME_READ8     in: REG               out: V
80 REM   1100 BME_READ16    in: REG               out: V (raw 16)
90 REM   1200 SEXT16        in/out: V             (sign extend 16->32)
100 REM  1300 BME_WRITEREG  in: REG, VAL
110 REM  2000 LOAD_CAL
120 REM  3000 COMPENSATE_T  in: ADCT              out: T (degC*100)
130 REM  4000 COMPENSATE_P  in: ADCP              out: P (Pa)
140 REM  5000 COMPENSATE_H  in: ADCH              out: H (RH*1024)
150 REM
160 REM ----- detect chip -----
170 LET REG = 0xD0
180 GOSUB 1000
190 LET ID = V
200 IF ID <> 0x60 THEN GOTO 900
210 PRINT "BME280 detected (chip id "; ID; ")"
220 GOSUB 2000
230 REM ctrl_hum = humidity oversample x1
240 LET REG = 0xF2 : LET VAL = 0x01 : GOSUB 1300
250 REM ctrl_meas = T x1, P x1, normal mode
260 LET REG = 0xF4 : LET VAL = 0x27 : GOSUB 1300
270 SLEEP 30000
280 REM ----- read raw samples -----
290 LET REG = 0xF7 : GOSUB 1000 : LET PMSB = V
300 LET REG = 0xF8 : GOSUB 1000 : LET PLSB = V
310 LET REG = 0xF9 : GOSUB 1000 : LET PXLS = V
320 LET REG = 0xFA : GOSUB 1000 : LET TMSB = V
330 LET REG = 0xFB : GOSUB 1000 : LET TLSB = V
340 LET REG = 0xFC : GOSUB 1000 : LET TXLS = V
350 LET REG = 0xFD : GOSUB 1000 : LET HMSB = V
360 LET REG = 0xFE : GOSUB 1000 : LET HLSB = V
370 LET ADCP = (PMSB << 12) OR (PLSB << 4) OR ((PXLS >> 4) AND 0x0F)
380 LET ADCT = (TMSB << 12) OR (TLSB << 4) OR ((TXLS >> 4) AND 0x0F)
390 LET ADCH = (HMSB << 8) OR HLSB
400 GOSUB 3000
410 LET TT = T
420 GOSUB 4000
430 LET PP = P
440 GOSUB 5000
450 LET HH = H
460 REM ----- print results -----
470 LET FRAC = TT - (TT / 100) * 100
480 IF FRAC < 0 THEN LET FRAC = 0 - FRAC
490 PRINT "Temperature: "; TT / 100; "."; FRAC; " C"
500 LET HPA = PP / 100
510 LET DEC = (PP - HPA * 100) / 10
520 PRINT "Pressure:    "; HPA; "."; DEC; " hPa"
530 LET HH = HH * 10 / 1024
540 PRINT "Humidity:    "; HH / 10; "."; HH - (HH / 10) * 10; " %"
550 END
560 REM
900 PRINT "BME280 not found (id="; ID; ")"
910 END
920 REM
1000 REM ----- BME_READ8: in REG, out V -----
1010 I2CSTART
1020 I2CWRITE 0xEC
1030 I2CWRITE REG
1040 I2CSTART
1050 I2CWRITE 0xED
1060 LET V = I2CREAD(1)
1070 I2CSTOP
1080 RETURN
1090 REM
1100 REM ----- BME_READ16: in REG, out V (little-endian 16) -----
1110 LET R16 = REG
1120 GOSUB 1000
1130 LET LO = V
1140 LET REG = R16 + 1
1150 GOSUB 1000
1160 LET V = (V << 8) OR LO
1170 RETURN
1180 REM
1200 REM ----- SEXT16: sign-extend low 16 bits of V -----
1210 IF (V AND 0x8000) <> 0 THEN LET V = V - 0x10000
1220 RETURN
1230 REM
1300 REM ----- BME_WRITEREG: in REG, VAL -----
1310 I2CSTART
1320 I2CWRITE 0xEC
1330 I2CWRITE REG
1340 I2CWRITE VAL
1350 I2CSTOP
1360 RETURN
1370 REM
2000 REM ----- LOAD_CAL -----
2010 LET REG = 0x88 : GOSUB 1100 : LET DT1 = V
2020 LET REG = 0x8A : GOSUB 1100 : GOSUB 1200 : LET DT2 = V
2030 LET REG = 0x8C : GOSUB 1100 : GOSUB 1200 : LET DT3 = V
2040 LET REG = 0x8E : GOSUB 1100 : LET DP1 = V
2050 LET REG = 0x90 : GOSUB 1100 : GOSUB 1200 : LET DP2 = V
2060 LET REG = 0x92 : GOSUB 1100 : GOSUB 1200 : LET DP3 = V
2070 LET REG = 0x94 : GOSUB 1100 : GOSUB 1200 : LET DP4 = V
2080 LET REG = 0x96 : GOSUB 1100 : GOSUB 1200 : LET DP5 = V
2090 LET REG = 0x98 : GOSUB 1100 : GOSUB 1200 : LET DP6 = V
2100 LET REG = 0x9A : GOSUB 1100 : GOSUB 1200 : LET DP7 = V
2110 LET REG = 0x9C : GOSUB 1100 : GOSUB 1200 : LET DP8 = V
2120 LET REG = 0x9E : GOSUB 1100 : GOSUB 1200 : LET DP9 = V
2130 LET REG = 0xA1 : GOSUB 1000 : LET DH1 = V
2140 LET REG = 0xE1 : GOSUB 1100 : GOSUB 1200 : LET DH2 = V
2150 LET REG = 0xE3 : GOSUB 1000 : LET DH3 = V
2160 LET REG = 0xE4 : GOSUB 1000 : LET E4 = V
2170 LET REG = 0xE5 : GOSUB 1000 : LET E5 = V
2180 LET V = (E4 << 4) OR (E5 AND 0x0F)
2190 IF (V AND 0x800) <> 0 THEN LET V = V - 0x1000
2200 LET DH4 = V
2210 LET REG = 0xE6 : GOSUB 1000 : LET E6 = V
2220 LET V = (E6 << 4) OR ((E5 >> 4) AND 0x0F)
2230 IF (V AND 0x800) <> 0 THEN LET V = V - 0x1000
2240 LET DH5 = V
2250 LET REG = 0xE7 : GOSUB 1000 : LET E7 = V
2260 LET V = E7
2270 IF (V AND 0x80) <> 0 THEN LET V = V - 0x100
2280 LET DH6 = V
2290 RETURN
2300 REM
3000 REM ----- COMPENSATE_T: in ADCT, out T (degC*100), sets TFINE -----
3010 LET V1 = SAR((SAR(ADCT, 3) - (DT1 << 1)) * DT2, 11)
3020 LET X = SAR(ADCT, 4) - DT1
3030 LET V2 = SAR(SAR(X * X, 12) * DT3, 14)
3040 LET TFINE = V1 + V2
3050 LET T = SAR(TFINE * 5 + 128, 8)
3060 RETURN
3070 REM
4000 REM ----- COMPENSATE_P: in ADCP, out P (Pa) -----
4010 LET V1 = SAR(TFINE, 1) - 64000
4020 LET V2 = SAR(SAR(V1, 2) * SAR(V1, 2), 11) * DP6
4030 LET V2 = V2 + ((V1 * DP5) << 1)
4040 LET V2 = SAR(V2, 2) + (DP4 << 16)
4050 LET V1 = SAR(SAR(DP3 * SAR(SAR(V1, 2) * SAR(V1, 2), 13), 3) + SAR(DP2 * V1, 1), 18)
4060 LET V1 = SAR((32768 + V1) * DP1, 15)
4070 IF V1 = 0 THEN LET P = 0 : RETURN
4080 LET P = (1048576 - ADCP - SAR(V2, 12)) * 3125
4085 LET PSIGN = P >> 31
4090 IF PSIGN = 0 THEN LET P = (P << 1) / V1
4100 IF PSIGN <> 0 THEN LET P = (P / V1) * 2
4110 LET V1 = SAR(DP9 * SAR(SAR(P, 3) * SAR(P, 3), 13), 12)
4120 LET V2 = SAR(SAR(P, 2) * DP8, 13)
4130 LET P = P + SAR(V1 + V2 + DP7, 4)
4140 RETURN
4150 REM
5000 REM ----- COMPENSATE_H: in ADCH, out H (RH*1024) -----
5010 LET V = TFINE - 76800
5020 LET A = SAR((ADCH << 14) - (DH4 << 20) - (DH5 * V) + 16384, 15)
5030 LET B = SAR((SAR(SAR(V * DH6, 10) * (SAR(V * DH3, 11) + 32768), 10) + 2097152) * DH2 + 8192, 14)
5040 LET V = A * B
5050 LET V = V - SAR(SAR(SAR(V, 15) * SAR(V, 15), 7) * DH1, 4)
5060 IF V < 0 THEN LET V = 0
5070 IF V > 419430400 THEN LET V = 419430400
5080 LET H = SAR(V, 12)
5090 RETURN
